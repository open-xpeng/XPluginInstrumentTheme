<com.xiaopeng.xui.widget.XRelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_alignParentEnd="true"
    android:background="@android:color/transparent"
    tools:context="com.xiaopeng.xposed.instrument.widgets.MapRightInfoViewGroup">

    <com.xiaopeng.xui.widget.XRelativeLayout
        android:layout_width="@dimen/info_width"
        android:layout_height="@dimen/info_height"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="@dimen/info_margin_end"
        android:background="@android:color/transparent">

        <com.xiaopeng.xui.widget.XRecyclerView
            android:id="@+id/info_list"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/info_list_height"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/info_list_margin_end"
            android:background="@drawable/right_info_bg_chosen_tab"
            android:visibility="invisible" />
    </com.xiaopeng.xui.widget.XRelativeLayout>

    <com.xiaopeng.xui.widget.XRelativeLayout
        android:id="@+id/card_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:visibility="gone">

        <com.xiaopeng.instrument.widget.sr.SRMapCardView
            android:id="@+id/info_map"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/info_map_margin_start"
            android:visibility="gone" />

        <com.xiaopeng.instrument.widget.sr.SRMediaCardView
            android:id="@+id/info_media"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/info_map_margin_start"
            android:visibility="gone" />

        <com.xiaopeng.instrument.widget.sr.SRCarConditionCardView
            android:id="@+id/info_car_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/info_map_margin_start"
            android:visibility="gone" />

        <com.xiaopeng.instrument.widget.sr.SRPowerConsumptionCardView
            android:id="@+id/info_power_consumption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/info_map_margin_start"
            android:visibility="gone" />

        <com.xiaopeng.instrument.widget.sr.SROdoMeterCardView
            android:id="@+id/info_power_odo_meter"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/info_map_margin_start"
            android:visibility="gone" />
    </com.xiaopeng.xui.widget.XRelativeLayout>
</com.xiaopeng.xui.widget.XRelativeLayout>